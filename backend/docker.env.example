# Backend/shared env vars used by docker-compose services
# Copy to backend/docker.env and set real secrets before running.

GEMINI_API_KEY=your_gemini_api_key

# Java API <-> frontend and scheme engine wiring
APP_FRONTEND_URL=http://localhost:5173
APP_SCHEME_ENGINE_BASE_URL=http://scheme-engine:3001
APP_SCHEME_ENGINE_VECTOR_SEARCH_ENDPOINT=/vector-search
APP_SCHEME_ENGINE_CONNECT_TIMEOUT_MS=3000
APP_SCHEME_ENGINE_READ_TIMEOUT_MS=8000

# Azure Speech values used by stt-token-service mapping
AZURE_SPEECH_KEY=your_azure_speech_subscription_key
AZURE_SPEECH_REGION=centralindia
SPEECH_KEY=your_azure_speech_subscription_key
SPEECH_REGION=centralindia

# Real Azure Storage connection string for Azure Functions runtime
AzureWebJobsStorage=your_azure_storage_connection_string
